APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Canonical hostname enforcement.
# Set to your primary domain (e.g. "gigresource.com") to 301-redirect
# every other hostname (dashboard.*, www.*, etc.) onto it.
# Leave EMPTY in local/dev to disable.
CANONICAL_HOST=
CANONICAL_REDIRECT_HTTPS=true
CANONICAL_REDIRECT_STATUS=301

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=khadija_local
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Temporary override to bypass plan gates on the AI tools.
# When true, every authenticated user gets unlimited access to
# Budget Allocator / Vendor Matchmaking / Review Writer regardless
# of their subscription plan. Use during UAT / soft-launch only.
# Flip back to false once paid plans go live.
AI_FEATURES_FREE_FOR_ALL=false

# Stripe (keys managed in Admin Settings, webhook secret here for signature verification)
STRIPE_WEBHOOK_SECRET=

# Payments go-live lock. While false (default), NO real money can be charged —
# any live charge attempt is blocked so the platform can't take real payments
# before launch. TEST mode (Admin → Payment Settings → mode = Test) with test
# keys/cards still works fully for testing. At launch: set this to true AND
# switch Payment Settings to Live with live keys.
PAYMENTS_GO_LIVE=false

# Sentry — error tracking + performance monitoring.
# Leave SENTRY_LARAVEL_DSN blank in local; set it in staging/production.
# Adjust SENTRY_TRACES_SAMPLE_RATE upward (0.0 → 1.0) for richer perf data.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

VITE_APP_NAME="${APP_NAME}"
